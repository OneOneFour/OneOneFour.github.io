---
import Layout from '../layouts/Layout.astro'

// --- Edit these to change what shows up on the splash page ---------------

const socialLinks = [
  { label: 'GitHub', href: 'https://www.github.com/OneOneFour', icon: '/icons/github.svg' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/robert-king-8263b6140/', icon: '/icons/linkedin.svg' },
]

const email = 'robertcking98@gmail.com'

// Flip to true once /public/Robert_King_CV.pdf is the version you want linked.
const showCvLink = false
// ---------------------------------------------------------------------------
---

<Layout title="Robert King">
  <main class="splash">
    <!--
      To add a profile photo: drop an image at public/profile.jpg, then
      uncomment the <img> below.
    -->
    <!-- <img class="photo" src="/profile.jpg" alt="Robert King" /> -->
    <img src="/images/mugshota.png" alt="Photo of me (Rob that is)" class="photo">
    <h1 class="name">Robert King</h1>

    <div class="bio">
      <!-- EDIT YOUR BIO HERE --------------------------------------------- -->
      <p>Late stage graduate student in at Stanford University.</p>
      <p>Interested in predicting the future (particularly involving complicated things). </p>
      <p>Curator of climate models.</p>
      <p class="old">Former developer at Octopus Energy and GMV NSL.</p>

      <!-- ------------------------------------------------------------------ -->
    </div>

    <div class="links">
      <div class="social">
        {socialLinks.map((link) => (
          <a href={link.href} aria-label={link.label}>
            <img src={link.icon} alt={link.label} />
          </a>
        ))}
      </div>
      <a class="bubble" href={`mailto:${email}`}>
        <img src="/icons/email.svg" alt="Email" />
        <span>{email}</span>
      </a>


      {showCvLink && (
        <a class="bubble" href="/files/Robert_King_CV.pdf">
          <img src="/icons/cv.svg" alt="Download CV" />
          <span>Curriculum Vitae</span>
        </a>
      )}
    </div>
  </main>
</Layout>
